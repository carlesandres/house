{
	"name": "@carlesandres/house",
	"version": "0.4.2",
	"description": "TUI-first markdown reader on opentui",
	"type": "module",
	"license": "MIT",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/carlesandres/house.git"
	},
	"bugs": {
		"url": "https://github.com/carlesandres/house/issues"
	},
	"homepage": "https://github.com/carlesandres/house#readme",
	"keywords": [
		"markdown",
		"reader",
		"terminal",
		"tui",
		"bun",
		"opentui",
		"glow",
		"house"
	],
	"files": [
		"src",
		"README.md",
		"LICENSE",
		"CHANGELOG.md"
	],
	"publishConfig": {
		"access": "public",
		"provenance": true,
		"registry": "https://registry.npmjs.org/"
	},
	"bin": {
		"house": "src/index.tsx"
	},
	"scripts": {
		"dev": "bun --watch src/index.tsx",
		"start": "bun run src/index.tsx",
		"typecheck": "tsc --noEmit",
		"lint": "oxlint --tsconfig tsconfig.json src/",
		"format": "oxfmt src/",
		"format:check": "oxfmt --check src/",
		"test": "bun test",
		"test:pty": "HOUSE_PTY=1 bun test test/pty/",
		"build:themes": "bun run dev/build-themes.ts",
		"repro:pty-codeblocks": "bun run dev/repro-pty-codeblocks.ts",
		"prepare": "git config core.hooksPath .githooks 2>/dev/null || true"
	},
	"dependencies": {
		"@effect/atom-react": "4.0.0-beta.70",
		"@opentui/core": "0.2.15",
		"@opentui/react": "0.2.15",
		"effect": "4.0.0-beta.70",
		"ignore": "^7.0.5",
		"marked": "^18.0.4",
		"react": "19.2.6",
		"scheduler": "0.27.0"
	},
	"devDependencies": {
		"@effect/language-service": "0.86.2",
		"@types/bun": "1.3.14",
		"@types/react": "19.2.15",
		"oxfmt": "0.51.0",
		"oxlint": "1.66.0",
		"tuistory": "^0.8.0",
		"typescript": "6.0.3"
	}
}
